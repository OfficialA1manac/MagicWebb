# MagicWebb — single binary (Go Fiber + HTMX)
# Copy to .env and fill in values. Run: make dev
# Ground truth for every variable is backend/internal/config/config.go.

# ── Required ──────────────────────────────────────────────────────────────────
# Neon Postgres serverless connection (port 5432). sslmode=require is enforced.
# Neon free tier: 10 concurrent connections, 500 MiB storage.
POSTGRES_URL=postgresql://user:password@ep-<project>.us-east-2.aws.neon.tech/magicwebb?sslmode=require

# Optional read-replica connection. Set to a Neon read-only branch endpoint
# to offload read-heavy API queries (listings, auctions, activity, search)
# to the replica while writes always hit the primary. Format matches the
# primary POSTGRES_URL but points to a read-only branch:
#   postgresql://user:password@ep-<branch>-reader.us-east-2.aws.neon.tech/magicwebb?sslmode=require
# The "-reader" suffix is added by Neon when creating a read-only branch.
# When unset, all reads use the primary pool — no behaviour change.
READ_POOL_URL=

RPC_URL=https://coston2-api.flare.network/ext/C/rpc
CHAIN_ID=114

# Optional rotation set: comma-separated endpoints for round-robin + <3s failover.
# Unset = single RPC_URL. Fill with the 3 public Coston2 RPCs when provisioned.
RPC_URLS=https://coston2-api.flare.network/ext/C/rpc,https://coston2.enosys.global/ext/C/rpc,https://rpc.ankr.com/flare_coston2

# Contract addresses — v3 Coston2 deploy 2026-06-10, gas-optimized (block 31630816).
# Manager: 0x852a9bD9F4394fC565E5602434Bba365c8fb70b5
MARKETPLACE_ADDR=0x06BF7BA62B51DCE7BE24acBdB906Af9ed8853906
AUCTION_ADDR=0xA890008cc572809f255934aD8c1De2994B015CBF
OFFERBOOK_ADDR=0x53e27c0fEeA6ADb38D6D420c4CE009bc62cA89C1
NFT_ADDR=0xe96Afb7b664Ab90d74b778AdFE47D8342495807F

# Min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=

# ── Optional — server ─────────────────────────────────────────────────────────
ENV=development                       # "production" disables pretty logs
HTTP_ADDR=:8080                       # listen address
FRONTEND_URL=http://localhost:8080    # CORS origin (the binary serves its own UI)
SIWE_DOMAIN=localhost                 # domain bound into the Sign-In-with-Ethereum message

# ── Optional — indexer tuning ─────────────────────────────────────────────────
INDEX_FROM_BLOCK=31630816             # start block for the chain indexer
GETLOGS_CHUNK=30                      # eth_getLogs chunk size (Flare public RPC caps ~30)
GETLOGS_BLOCK_CAP=30                  # max block span per request (0 = unlimited, private RPC)

# ── Optional — trending score weights ─────────────────────────────────────────
SCORE_W_VIEWS=0.3
SCORE_W_BIDS=0.5
SCORE_W_VOLUME=0.2
SCORE_DECAY=0.05

# ── Optional — keeper / admin / fee sweep ──────────────────────────────────
KEEPER_KEY=                           # hex ECDSA key; enables auction auto-settlement
SERVICE_TOKEN=                        # bearer token for the admin reindex endpoint (empty = disabled)
ADMIN_ALLOWLIST=                      # comma-separated wallet addresses allowed to call /admin/*

# ── Optional — Gnosis Safe fee sweep (Zodiac Allowance Module) ────────────────
# Required for the fee sweep keeper to auto-transfer marketplace fees from
# the Gnosis Safe to your personal wallet. The Safe must have the Zodiac
# Allowance Module enabled and the keeper address added as a delegate (one-time
# on-chain setup after DeploySafe.s.sol runs).
SAFE_ADDR=                            # Gnosis Safe multisig address (feeRecipient)
PERSONAL_WALLET_ADDR=                 # Your personal wallet address that receives swept fees
FEE_SWEEP_MIN_WEI=100000000000000000  # Minimum Safe balance (wei) before sweeping; default 0.1 native token

# ── Optional — wallet ──────────────────────────────────────────────────────────
WC_PROJECT_ID=                        # WalletConnect v2 project id (cloud.walletconnect.com); empty = MetaMask only

# ── Optional — integrations (unset = feature off) ─────────────────────────────
ROYALTY_ADDR=                         # royalty registry contract (empty = no registry lookups)
SENTRY_DSN=                           # error reporting
OTEL_EXPORTER_OTLP_ENDPOINT=          # OpenTelemetry traces
