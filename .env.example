# MagicWebb — single binary (Go Fiber + HTMX)
# Copy to .env and fill in values. Run: make dev
# Ground truth for every variable is backend/internal/config/config.go.

# ── Required ──────────────────────────────────────────────────────────────────
# Supabase Postgres pooler (port 6543 = transaction-mode pooler)
POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pool_mode=transaction

RPC_URL=https://coston2-api.flare.network/ext/C/rpc
CHAIN_ID=114

# Optional rotation set: comma-separated endpoints for round-robin + <3s failover.
# Unset = single RPC_URL. Fill with the 3 public Coston2 RPCs when provisioned.
RPC_URLS=https://coston2-api.flare.network/ext/C/rpc,https://coston2.enosys.global/ext/C/rpc,https://rpc.ankr.com/flare_coston2

# Contract addresses — v2 Coston2 deploy 2026-06-10 (block 31610228).
# Manager: 0xFDcAE06C12d5E54Ff3304B29C415F006B553627F
MARKETPLACE_ADDR=0x6E5d2332a30bE3aBC35a0dC795583a06cfedFc9C
AUCTION_ADDR=0xAF76199b6BB77fEB1E1D8541C30557f3231F6F5c
OFFERBOOK_ADDR=0x9D38CB500551BfDD106CA8052C9Bfd146A5f6CbA

# Min 32 chars. Generate: openssl rand -hex 32
JWT_SECRET=

# ── Optional — server ─────────────────────────────────────────────────────────
ENV=development                       # "production" disables pretty logs
HTTP_ADDR=:8080                       # listen address
FRONTEND_URL=http://localhost:8080    # CORS origin (the binary serves its own UI)
SIWE_DOMAIN=localhost                 # domain bound into the Sign-In-with-Ethereum message

# ── Optional — indexer tuning ─────────────────────────────────────────────────
INDEX_FROM_BLOCK=31610228             # start block for the chain indexer
GETLOGS_CHUNK=30                      # eth_getLogs chunk size (Flare public RPC caps ~30)
GETLOGS_BLOCK_CAP=30                  # max block span per request (0 = unlimited, private RPC)

# ── Optional — trending score weights ─────────────────────────────────────────
SCORE_W_VIEWS=0.3
SCORE_W_BIDS=0.5
SCORE_W_VOLUME=0.2
SCORE_DECAY=0.05

# ── Optional — keeper / admin ─────────────────────────────────────────────────
KEEPER_KEY=                           # hex ECDSA key; enables auction auto-settlement
SERVICE_TOKEN=                        # bearer token for the admin reindex endpoint (empty = disabled)
ADMIN_ALLOWLIST=                      # comma-separated wallet addresses allowed to call /admin/*

# ── Optional — wallet ──────────────────────────────────────────────────────────
WC_PROJECT_ID=                        # WalletConnect v2 project id (cloud.walletconnect.com); empty = MetaMask only

# ── Optional — integrations (unset = feature off) ─────────────────────────────
ROYALTY_ADDR=                         # royalty registry contract (empty = no registry lookups)
PINATA_JWT=                           # IPFS pinning for uploads
SENTRY_DSN=                           # error reporting
OTEL_EXPORTER_OTLP_ENDPOINT=          # OpenTelemetry traces
