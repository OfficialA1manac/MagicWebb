# MagicWebb — copy to `.env.local` (the only env file used by Next.js and `make deploy`).
# Production-style deployment: set these on the host; chain stays Coston2 (114) with your Coston2 contracts.
# Later for Flare mainnet: deploy new contracts, set NEXT_PUBLIC_* to mainnet chain id, RPC, and addresses.

# --- Required for app + `next build` (NEXT_PUBLIC_* inlined at build time) ---
NEXT_PUBLIC_CHAIN_ID=114
NEXT_PUBLIC_RPC_URL=https://coston2-api.flare.network/ext/C/rpc
NEXT_PUBLIC_EXPLORER_URL=https://coston2-explorer.flare.network
NEXT_PUBLIC_CURRENCY_SYMBOL=C2FLR
NEXT_PUBLIC_CHAIN_NAME=Flare Coston2

NEXT_PUBLIC_MARKETPLACE_ADDR=0x767F7fF7c66673488a30053C025C153E13b6BfAa
NEXT_PUBLIC_AUCTION_ADDR=0x6016688AfFAF5427E1f8100160A6378Da2B1476a
NEXT_PUBLIC_OFFER_ADDR=0x0C7112Ec22262d1E423132e35bC87E33abF64a22

# --- WalletConnect / Reown (https://cloud.reown.com) — optional but recommended for mobile wallets ---
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
# Origin shown in the WalletConnect modal (use your production URL when deployed)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- Optional: Search / Profile wallet scan (comma-separated ERC-721 collection addresses) ---
NEXT_PUBLIC_TRACKED_COLLECTIONS=0x9a6aC1e5CBeF7d477fC1B99f5c7f20999370184B
# First block for Marketplace `Listed` log scan — skip genesis scan for faster loads
NEXT_PUBLIC_INDEX_FROM_BLOCK=30437062
# Blocks per `eth_getLogs` chunk. Coston2 public RPC caps at ~30 blocks per call.
NEXT_PUBLIC_INDEX_CHUNK_BLOCKS=30
# Hard cap per getLogs range. Set to 0 on your own node to disable capping.
NEXT_PUBLIC_INDEX_GETLOGS_BLOCK_CAP=30

# --- Optional: `make deploy` / verify — set ONLY in `frontend/.env.local` (never commit real values) ---
PRIVATE_KEY=
# Fee recipient wallet for new deployments (immutable post-deploy — cannot change without redeploying).
# The 1.5% platform fee is hardcoded in contracts and sent directly to this address.
CREATOR_ADDR=
ROUTESCAN_API_KEY=

# --- Backend API (Go, port 8080) ---
NEXT_PUBLIC_API_URL=http://localhost:8080
