---
import WalletConnect from '../components/WalletConnect';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>MagicWebb — NFT Marketplace on Flare</title>
    <meta name="description" content="MagicWebb is a decentralized NFT marketplace on Flare Network. Buy, sell, and auction NFTs with low fees." />
    <meta name="theme-color" content="#0f172a" />

    <!-- Open Graph -->
    <meta property="og:title" content="MagicWebb — NFT Marketplace on Flare" />
    <meta property="og:description" content="Buy, sell, and auction NFTs on Flare Network" />
    <meta property="og:type" content="website" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />

    <style>
      /* ── Reset ── */
      *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
      html { font-family: 'Inter', system-ui, -apple-system, sans-serif; background: #0f172a; color: #e2e8f0; }
      body { min-height: 100vh; }
      a { color: inherit; text-decoration: none; }
      button { font-family: inherit; cursor: pointer; }

      /* ── Gradient background ── */
      body::before {
        content: '';
        position: fixed;
        inset: 0;
        background:
          radial-gradient(ellipse 80% 50% at 50% -20%, rgba(139, 92, 246, 0.15), transparent),
          radial-gradient(ellipse 50% 30% at 80% 80%, rgba(99, 102, 241, 0.1), transparent),
          radial-gradient(ellipse 30% 50% at 0% 50%, rgba(139, 92, 246, 0.08), transparent);
        pointer-events: none;
        z-index: 0;
      }

      .layout { position: relative; z-index: 1; min-height: 100vh; display: flex; flex-direction: column; }

      /* ── Navbar ── */
      nav {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1rem 1.5rem;
        border-bottom: 1px solid rgba(148, 163, 184, 0.1);
        backdrop-filter: blur(12px);
        background: rgba(15, 23, 42, 0.8);
      }
      .logo {
        font-size: 1.25rem;
        font-weight: 700;
        background: linear-gradient(135deg, #8b5cf6, #6366f1, #a78bfa);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .nav-links { display: flex; gap: 1.5rem; align-items: center; }
      .nav-links a {
        color: #94a3b8;
        font-size: 0.875rem;
        font-weight: 500;
        transition: color 0.2s;
      }
      .nav-links a:hover { color: #e2e8f0; }

      /* ── Hero ── */
      .hero {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: 2rem;
        padding: 4rem 1.5rem;
        text-align: center;
      }
      .hero h1 {
        font-size: clamp(2.5rem, 6vw, 4rem);
        font-weight: 700;
        line-height: 1.1;
        background: linear-gradient(135deg, #e2e8f0, #a78bfa, #6366f1);
        -webkit-background-clip: text;
        -webkit-text-fill-color: transparent;
        background-clip: text;
      }
      .hero p {
        max-width: 32rem;
        color: #94a3b8;
        font-size: 1.125rem;
        line-height: 1.6;
      }
      .status-note {
        color: #64748b;
        font-size: 0.8125rem;
      }

      /* ── Footer ── */
      footer {
        padding: 1.5rem;
        text-align: center;
        color: #475569;
        font-size: 0.8125rem;
        border-top: 1px solid rgba(148, 163, 184, 0.1);
      }
    </style>
  </head>
  <body>
    <div class="layout">
      <nav>
        <span class="logo">MagicWebb</span>
        <div class="nav-links">
          <a href="/">Home</a>
          <a href="/listings">Listings</a>
          <a href="/auctions">Auctions</a>
        </div>
        <!-- WalletConnect is fully self-contained (init + providers + UI).
             client:only="react" skips SSR — the mount point is a server-rendered
             <div> placeholder, hydrated by React in the browser. -->
        <WalletConnect client:only="react" />
      </nav>

      <main class="hero">
        <h1>Trade NFTs on Flare</h1>
        <p>
          MagicWebb is a fully decentralized NFT marketplace on Flare Network.
          Buy, sell, and auction digital assets with the lowest fees on the network.
        </p>
        <p class="status-note">
          Connect your wallet to start trading. Supports MetaMask, Trust Wallet,
          Rainbow, and any WalletConnect-compatible wallet.
        </p>
      </main>

      <footer>
        MagicWebb &mdash; Decentralized NFT Marketplace on Flare Network
      </footer>
    </div>
  </body>
</html>
