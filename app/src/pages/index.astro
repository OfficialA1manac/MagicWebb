---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalletConnect from '../components/WalletConnect';
---

<BaseLayout title="Trade NFTs on Flare" description="MagicWebb is a fully decentralized NFT marketplace on Flare Network. Buy, sell, and auction digital assets with the lowest fees." activeNav="/">
  <WalletConnect slot="wallet" client:only="react" />

  <!-- ═══════════════ HERO ═══════════════ -->
  <section class="hero-parallax" style="text-align:center;padding:5rem 1.5rem 4rem;position:relative;overflow:hidden;">
    <!-- Floating decorative blobs -->
    <div class="float" style="position:absolute;top:10%;left:5%;width:180px;height:180px;border-radius:50%;background:radial-gradient(circle,rgba(125,211,252,0.15),transparent 70%);pointer-events:none;"></div>
    <div class="float-delayed" style="position:absolute;top:20%;right:8%;width:140px;height:140px;border-radius:50%;background:radial-gradient(circle,rgba(167,139,250,0.12),transparent 70%);pointer-events:none;"></div>
    <div class="float-slow" style="position:absolute;bottom:15%;left:20%;width:120px;height:120px;border-radius:50%;background:radial-gradient(circle,rgba(252,211,77,0.08),transparent 70%);pointer-events:none;"></div>

    <!-- Testnet badge -->
    <div class="reveal" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.375rem 0.75rem;border-radius:999px;background:rgba(14,165,233,0.12);border:1px solid rgba(125,211,252,0.35);color:#bae6fd;font-size:0.625rem;font-weight:800;text-transform:uppercase;letter-spacing:0.1em;margin-bottom:1.5rem;box-shadow:0 0 22px -6px rgba(56,189,248,0.45);">
      <span style="width:0.375rem;height:0.375rem;border-radius:50%;background:#7dd3fc;animation:pulse 2s infinite;"></span>
      ✦ Flare Coston2 Testnet
    </div>

    <!-- Headline -->
    <h1 class="reveal" style="font-size:clamp(2.75rem,7vw,5rem);font-weight:900;line-height:0.95;letter-spacing:-0.03em;margin-bottom:1.25rem;">
      <span style="color:#fafafa;">Trade NFTs on</span><br/>
      <span class="brand-text">Flare Network</span>
    </h1>

    <p class="reveal" style="max-width:34rem;margin:0 auto 2rem;color:rgba(255,255,255,0.55);font-size:1.0625rem;line-height:1.65;">
      Non-custodial marketplace.&nbsp;
      <span style="color:#7dd3fc;font-weight:700;">Fixed-price listings</span>,&nbsp;
      <span style="color:#a78bfa;font-weight:700;">English auctions</span>,&nbsp;
      <span style="color:#fcd34d;font-weight:700;">signed offers</span>.
      Your keys, your NFTs, your control.
    </p>

    <!-- CTA buttons -->
    <div class="reveal" style="display:flex;gap:0.75rem;justify-content:center;flex-wrap:wrap;margin-bottom:3rem;">        <a href="/listings" class="btn-sky" style="padding:0.875rem 1.75rem;border-radius:0.875rem;color:#fafafa;font-weight:800;font-size:0.9375rem;transition:all 0.2s;box-shadow:0 0 30px -4px rgba(56,189,248,0.45),0 8px 20px -8px rgba(14,165,233,0.3);display:inline-flex;align-items:center;gap:0.5rem;">
        Browse Listings
        <span style="font-size:1.125rem;">→</span>
      </a>
      <a href="/auctions" class="btn-violet" style="padding:0.875rem 1.75rem;border-radius:0.875rem;color:#fafafa;font-weight:800;font-size:0.9375rem;transition:all 0.2s;box-shadow:0 0 30px -4px rgba(167,139,250,0.45),0 8px 20px -8px rgba(124,58,237,0.3);display:inline-flex;align-items:center;gap:0.5rem;">
        Live Auctions
        <span style="font-size:1.125rem;">♕</span>
      </a>
      <a href="/metrics" style="padding:0.875rem 1.75rem;border-radius:0.875rem;background:rgba(255,255,255,0.06);color:#fafafa;font-weight:800;font-size:0.9375rem;border:1px solid rgba(255,255,255,0.12);transition:all 0.2s;display:inline-flex;align-items:center;gap:0.5rem;">
        <span style="color:#fcd34d;">▦</span>
        Metrics
      </a>
    </div>

    <!-- Live counters — data fetched client-side -->
    <div class="reveal" style="display:flex;justify-content:center;gap:1rem;flex-wrap:wrap;">
      <div style="padding:1rem 1.25rem;border-radius:1rem;background:rgba(15,15,19,0.8);border:1px solid rgba(255,255,255,0.08);backdrop-filter:blur(12px);min-width:110px;">
        <div id="counter-listings" class="count-pop" style="font-size:1.75rem;font-weight:900;color:#fafafa;line-height:1;">—</div>
        <div style="font-size:0.625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:0.375rem;font-weight:700;">Listings</div>
      </div>
      <div style="padding:1rem 1.25rem;border-radius:1rem;background:rgba(15,15,19,0.8);border:1px solid rgba(167,139,250,0.25);backdrop-filter:blur(12px);min-width:110px;">
        <div id="counter-auctions" class="count-pop" style="font-size:1.75rem;font-weight:900;color:#c4b5fd;line-height:1;">—</div>
        <div style="font-size:0.625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:0.375rem;font-weight:700;">Auctions</div>
      </div>
      <div style="padding:1rem 1.25rem;border-radius:1rem;background:rgba(15,15,19,0.8);border:1px solid rgba(255,255,255,0.08);backdrop-filter:blur(12px);min-width:110px;">
        <div id="counter-collections" class="count-pop" style="font-size:1.75rem;font-weight:900;color:#fafafa;line-height:1;">—</div>
        <div style="font-size:0.625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:0.375rem;font-weight:700;">Collections</div>
      </div>
      <div style="padding:1rem 1.25rem;border-radius:1rem;background:rgba(15,15,19,0.8);border:1px solid rgba(252,211,77,0.25);backdrop-filter:blur(12px);min-width:110px;">
        <div id="counter-volume" class="count-pop" style="font-size:1.75rem;font-weight:900;color:#fde68a;line-height:1;">—</div>
        <div style="font-size:0.625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;letter-spacing:0.1em;margin-top:0.375rem;font-weight:700;">24h Volume</div>
      </div>
    </div>
  </section>

  <!-- ═══════════════ FEATURES ═══════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:3rem 1.5rem;">
    <h2 class="reveal" style="text-align:center;font-size:2rem;font-weight:800;margin-bottom:3rem;letter-spacing:-0.02em;">
      How it <span class="brand-text">Works</span>
    </h2>
    <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(240px,1fr));gap:1.5rem;">
      <div class="reveal" style="padding:1.75rem;border-radius:1.25rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(8px);text-align:center;">
        <div style="width:3rem;height:3rem;border-radius:1rem;background:linear-gradient(135deg,#7dd3fc,#0ea5e9);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:#09090b;font-size:1.5rem;box-shadow:0 0 22px -6px rgba(56,189,248,0.45);">⌬</div>
        <h3 style="font-size:1.125rem;font-weight:700;margin-bottom:0.5rem;color:#fafafa;">Connect Wallet</h3>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.45);line-height:1.5;">Link any WalletConnect-compatible wallet via QR code or deep link. Non-custodial — you keep your keys.</p>
      </div>
      <div class="reveal" style="padding:1.75rem;border-radius:1.25rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(8px);text-align:center;">
        <div style="width:3rem;height:3rem;border-radius:1rem;background:linear-gradient(135deg,#fcd34d,#f59e0b);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:#09090b;font-size:1.5rem;box-shadow:0 0 22px -6px rgba(251,191,36,0.5);">⚐</div>
        <h3 style="font-size:1.125rem;font-weight:700;margin-bottom:0.5rem;color:#fafafa;">Buy & Sell</h3>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.45);line-height:1.5;">Fixed-price listings with just 1.5% platform fee. Listing is free — you only pay when you sell.</p>
      </div>
      <div class="reveal" style="padding:1.75rem;border-radius:1.25rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(8px);text-align:center;">
        <div style="width:3rem;height:3rem;border-radius:1rem;background:linear-gradient(135deg,#a78bfa,#7c3aed);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:#fafafa;font-size:1.5rem;box-shadow:0 0 22px -6px rgba(167,139,250,0.45);">♕</div>
        <h3 style="font-size:1.125rem;font-weight:700;margin-bottom:0.5rem;color:#fafafa;">Auctions</h3>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.45);line-height:1.5;">English auctions with anti-snipe protection — any bid in the final 3 minutes extends the clock by 3 minutes.</p>
      </div>
      <div class="reveal" style="padding:1.75rem;border-radius:1.25rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.06);backdrop-filter:blur(8px);text-align:center;">
        <div style="width:3rem;height:3rem;border-radius:1rem;background:linear-gradient(135deg,#7dd3fc,#a78bfa);display:flex;align-items:center;justify-content:center;margin:0 auto 1rem;color:#fafafa;font-size:1.5rem;box-shadow:0 0 22px -6px rgba(139,92,246,0.45);">↗</div>
        <h3 style="font-size:1.125rem;font-weight:700;margin-bottom:0.5rem;color:#fafafa;">Make Offers</h3>
        <p style="font-size:0.875rem;color:rgba(255,255,255,0.45);line-height:1.5;">Submit signed offers on any NFT. Fully refundable until accepted — your funds stay in escrow.</p>
      </div>
    </div>
  </section>

  <!-- ═══════════════ TRENDING (client-side fetch) ═══════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:2rem 1.5rem;">
    <div class="reveal" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:#fafafa;display:flex;align-items:center;gap:0.75rem;">
        <span style="width:2.25rem;height:2.25rem;border-radius:0.75rem;background:linear-gradient(135deg,#fcd34d,#f59e0b);display:flex;align-items:center;justify-content:center;color:#09090b;font-size:1.125rem;box-shadow:0 0 22px -6px rgba(251,191,36,0.5);">↗</span>
        Trending Collections
      </h2>
      <a href="/metrics" style="font-size:0.8125rem;color:#7dd3fc;font-weight:700;transition:color 0.2s;">All metrics →</a>
    </div>
    <div id="trending-grid" class="reveal" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:1rem;">
      <div class="shimmer" style="padding:2rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:rgba(255,255,255,0.25);">Loading…</div>
    </div>
  </section>

  <!-- ═══════════════ RECENT LISTINGS ═══════════════ -->
  <section style="max-width:72rem;margin:0 auto;padding:2rem 1.5rem;">
    <div class="reveal" style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">
      <h2 style="font-size:1.5rem;font-weight:800;color:#fafafa;display:flex;align-items:center;gap:0.75rem;">
        <span style="width:2.25rem;height:2.25rem;border-radius:0.75rem;background:linear-gradient(135deg,#7dd3fc,#0ea5e9);display:flex;align-items:center;justify-content:center;color:#09090b;font-size:1.125rem;box-shadow:0 0 22px -6px rgba(56,189,248,0.45);">✦</span>
        Recent Listings
      </h2>
      <a href="/listings" style="font-size:0.8125rem;color:#7dd3fc;font-weight:700;transition:color 0.2s;">View all →</a>
    </div>
    <div id="recent-listings-grid" class="reveal" style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;">
      <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);"></div>
      <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);"></div>
      <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);"></div>
      <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);"></div>
    </div>
  </section>

  <!-- ═══════════════ CTA BANNER ═══════════════ -->
  <section class="reveal" style="max-width:72rem;margin:3rem auto;padding:0 1.5rem;">
    <div style="padding:3rem 2rem;border-radius:1.5rem;background:linear-gradient(135deg,rgba(125,211,252,0.08),rgba(167,139,250,0.08),rgba(252,211,77,0.05));border:1px solid rgba(255,255,255,0.08);text-align:center;position:relative;overflow:hidden;">
      <div class="float" style="position:absolute;top:-40px;right:-40px;width:160px;height:160px;border-radius:50%;background:radial-gradient(circle,rgba(125,211,252,0.2),transparent 70%);pointer-events:none;"></div>
      <h2 style="font-size:1.75rem;font-weight:800;margin-bottom:0.75rem;color:#fafafa;position:relative;">Ready to start trading?</h2>
      <p style="color:rgba(255,255,255,0.5);margin-bottom:1.5rem;font-size:0.9375rem;position:relative;">Connect your wallet and join the marketplace on Flare Network.</p>
      <a href="/listings" class="btn-sky" style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.875rem 1.75rem;border-radius:0.875rem;color:#fafafa;font-weight:800;font-size:0.9375rem;box-shadow:0 0 30px -4px rgba(56,189,248,0.45),0 8px 20px -8px rgba(14,165,233,0.3);position:relative;transition:all 0.2s;">
        Explore Listings <span style="font-size:1.125rem;">→</span>
      </a>
    </div>
  </section>

  <!-- Client-side data fetching for counters + trending + recent listings -->
  <script is:inline>
    // Fetch with retry helper (defined before use via hoisting)
    async function fetchWithRetry(url, retries) {
      for (let i = 0; i <= retries; i++) {
        try {
          const res = await fetch(url);
          if (res.ok) return res;
          if (res.status < 500) return res;
        } catch(e) {
          if (i === retries) throw e;
        }
        // No backoff after the last attempt
        if (i < retries) {
          await new Promise(function(r) { setTimeout(r, Math.pow(2, i) * 500); });
        }
      }
      throw new Error('Max retries exceeded');
    }

    (async function() {
      // HTML-escape helper for safe innerHTML injection
      function esc(s) { return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;'); }
      function weiToFLR(w,d){d=d||2;try{return(Number(BigInt(w||'0'))/1e18).toFixed(d);}catch(_){return'0.00';}}
      function shortAddr(a){if(!a||a.length<10)return a;return a.slice(0,6)+'...'+a.slice(-4);}

      try {
        // Fetch metrics for counters
        const mRes = await fetch('/api/v1/metrics');
        if (mRes.ok) {
          const m = await mRes.json();
          document.getElementById('counter-listings').textContent = m.listing_count || m.totalActiveListings || 0;
          document.getElementById('counter-auctions').textContent = m.auction_count || m.totalAuctions || 0;
          document.getElementById('counter-collections').textContent = m.collection_count || 0;
          const volWei = m.volume_24h_wei || m.grossVolumeWei;
          if (volWei) {
            const vol = weiToFLR(volWei);
            document.getElementById('counter-volume').innerHTML = vol + ' <span style="font-size:0.75rem;">C2FLR</span>';
          }
        } else {
          document.getElementById('counter-listings').textContent = '—';
          document.getElementById('counter-auctions').textContent = '—';
          document.getElementById('counter-collections').textContent = '—';
          document.getElementById('counter-volume').innerHTML = '—';
        }
      } catch(_) {
        const c1 = document.getElementById('counter-listings'); const c2 = document.getElementById('counter-auctions'); const c3 = document.getElementById('counter-collections'); const c4 = document.getElementById('counter-volume');
        if (c1) c1.textContent = '—'; if (c2) c2.textContent = '—'; if (c3) c3.textContent = '—'; if (c4) c4.textContent = '—';
      }

      // Fetch recent listings with retry logic
      try {
        const lRes = await fetchWithRetry('/api/v1/listings?limit=8&sort=recent', 2);
        const grid = document.getElementById('recent-listings-grid');
        if (lRes.ok) {
          try {
            let listings = await lRes.json();
            if (!Array.isArray(listings)) listings = [];
            if (listings.length) {
              grid.innerHTML = listings.map(function(item) {
                const price = weiToFLR(item.price_wei||'0', 4);
                const name = item.name || ('#' + (item.token_id||item.tokenID||''));
                const tokenId = item.token_id || item.tokenID || '';
                const coll = item.collection || '';
                const imgSrc = item.image_uri
                  ? item.image_uri.startsWith('/api/v1/img/')
                    ? item.image_uri
                    : '/api/v1/media?url=' + encodeURIComponent(item.image_uri) + '&id=' + encodeURIComponent(item.token_id || '')
                  : '';
                const verified = item.collection_verified || item.collectionVerified;
                return '<a href="/token/' + esc(coll) + '/' + esc(tokenId) + '" class="tilt-card" style="display:block;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.08);border-radius:1rem;overflow:hidden;transition:all 0.3s;cursor:pointer;">' +
                  '<div style="aspect-ratio:1;overflow:hidden;background:rgba(9,9,11,0.5);position:relative;">' +
                    (imgSrc ? '<img src="' + esc(imgSrc) + '" alt="' + esc(name) + '" loading="lazy" style="width:100%;height:100%;object-fit:cover;transition:transform 0.5s;" onerror="this.parentElement.innerHTML=\'<div style=display:flex;align-items:center;justify-content:center;height:100%;color:rgba(255,255,255,0.15);font-size:3rem;\\>🖼</div>\'">' : '<div style="display:flex;align-items:center;justify-content:center;height:100%;color:rgba(255,255,255,0.15);font-size:3rem;">🖼</div>') +
                    (verified ? '<span style="position:absolute;top:0.5rem;left:0.5rem;width:1.25rem;height:1.25rem;background:#7c3aed;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:0.625rem;color:#fff;font-weight:700;box-shadow:0 2px 8px rgba(124,58,237,0.4);" title="Verified">✓</span>' : '') +
                    '<div style="position:absolute;top:0.5rem;right:0.5rem;padding:0.25rem 0.625rem;border-radius:0.625rem;background:rgba(9,9,11,0.75);backdrop-filter:blur(8px);border:1px solid rgba(252,211,77,0.3);box-shadow:0 0 18px -4px rgba(251,191,36,0.45);">' +
                      '<span style="font-size:0.75rem;font-weight:900;color:#fde68a;">' + esc(price) + '</span> <span style="font-size:0.5625rem;color:rgba(253,224,138,0.7);font-weight:700;text-transform:uppercase;">C2FLR</span>' +
                    '</div>' +
                  '</div>' +
                  '<div style="padding:0.75rem;">' +
                    '<p style="font-size:0.625rem;color:rgba(255,255,255,0.3);font-family:JetBrains Mono,monospace;text-transform:uppercase;margin-bottom:0.25rem;">' + esc(shortAddr(coll)) + '</p>' +
                    '<p style="font-size:0.875rem;font-weight:700;color:#fafafa;">' + esc(name) + '</p>' +
                  '</div>' +
                '</a>';
              }).join('');
            } else {
              grid.innerHTML = '<div style="padding:3rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:rgba(255,255,255,0.3);grid-column:1/-1;"><div style="font-size:2rem;margin-bottom:0.5rem;opacity:0.2;">✦</div><p>No listings yet — <a href="/listings" style="color:#7dd3fc;font-weight:700;">be the first to list an NFT</a></p></div>';
            }
          } catch(_json) {
            if (grid) grid.innerHTML = '<div style="padding:3rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:#fca5a5;grid-column:1/-1;">Could not parse listings — <button onclick="location.reload()" style="background:none;border:none;color:#7dd3fc;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:underline;">retry</button></div>';
          }
        } else {
          if (grid) grid.innerHTML = '<div style="padding:3rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:#fca5a5;grid-column:1/-1;">Could not load listings — <button onclick="location.reload()" style="background:none;border:none;color:#7dd3fc;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:underline;">retry</button></div>';
        }
    } catch(_e) {
      const gridEl = document.getElementById('recent-listings-grid');
        if (gridEl) gridEl.innerHTML = '<div style="padding:3rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:#fca5a5;grid-column:1/-1;">Could not load listings — <button onclick="location.reload()" style="background:none;border:none;color:#7dd3fc;font-weight:700;cursor:pointer;font-family:inherit;text-decoration:underline;">retry</button></div>';
      }

      try {
        // Fetch trending collections
        const tRes = await fetch('/api/v1/trending');
        if (tRes.ok) {
          const trending = await tRes.json();
          const grid = document.getElementById('trending-grid');
          if (trending && trending.length) {
            grid.innerHTML = trending.slice(0, 4).map(function(t) {
              return '<a href="/collection/' + esc(t.collection) + '" style="display:block;padding:1.5rem;border-radius:1rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.06);transition:all 0.3s;text-align:center;">' +
                '<div style="font-size:2rem;margin-bottom:0.5rem;color:rgba(255,255,255,0.2);">🗂</div>' +
                '<p style="font-size:0.75rem;font-weight:600;color:rgba(255,255,255,0.7);font-family:JetBrains Mono,monospace;">' + esc(t.collection ? t.collection.slice(0,6) + '...' + t.collection.slice(-4) : '') + '</p>' +
                '<p style="font-size:0.6875rem;color:rgba(255,255,255,0.35);margin-top:0.25rem;">Score ' + esc(t.score ? t.score.toFixed(1) : '—') + '</p>' +
              '</a>';
            }).join('');
          } else {
            grid.innerHTML = '<div class="shimmer" style="padding:3rem;border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);text-align:center;color:rgba(255,255,255,0.3);grid-column:1/-1;">No trending data yet</div>';
          }
        }
      } catch(_) {
        const grid2 = document.getElementById('trending-grid');
        if (grid2) grid2.innerHTML = '<div style="padding:3rem;border-radius:1rem;background:rgba(239,68,68,0.06);border:1px solid rgba(239,68,68,0.15);text-align:center;color:#fca5a5;grid-column:1/-1;">Could not load trending — please try again</div>';
      }
    })();

    // 3D tilt effect on cards
    document.addEventListener('mouseover', function(e) {
      const card = e.target.closest('.tilt-card');
      if (!card) return;
      const rect = card.getBoundingClientRect();
      const x = e.clientX - rect.left;
      const y = e.clientY - rect.top;
      const centerX = rect.width / 2;
      const centerY = rect.height / 2;
      const rotateX = (y - centerY) / centerY * -8;
      const rotateY = (x - centerX) / centerX * 8;
      card.style.transform = 'perspective(1000px) rotateX(' + rotateX + 'deg) rotateY(' + rotateY + 'deg) scale3d(1.02,1.02,1.02)';
      card.style.boxShadow = '0 20px 60px rgba(139,92,246,0.2)';
      card.style.borderColor = 'rgba(167,139,250,0.4)';
    });
    document.addEventListener('mouseout', function(e) {
      const card = e.target.closest('.tilt-card');
      if (!card) return;
      if (card.contains(e.relatedTarget)) return;
      card.style.transform = 'perspective(1000px) rotateX(0deg) rotateY(0deg) scale3d(1,1,1)';
      card.style.boxShadow = '';
      card.style.borderColor = 'rgba(255,255,255,0.08)';
    });
  </script>
</BaseLayout>
