---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalletConnect from '../components/WalletConnect';
---

<BaseLayout title="Profile" description="Your MagicWebb profile — NFTs, listings, auctions, and activity" activeNav="/profile">
  <WalletConnect slot="wallet" client:only="react" />

  <section style="max-width:80rem;margin:0 auto;padding:2rem 1.5rem;">
    <div id="profile-root">
      <!-- Loading skeleton -->
      <div class="shimmer" style="display:flex;align-items:center;gap:1rem;margin-bottom:1.5rem;padding:1.5rem;border-radius:1.25rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);">
        <div style="width:4.5rem;height:4.5rem;border-radius:1rem;background:rgba(255,255,255,0.04);flex-shrink:0;"></div>
        <div style="flex:1;">
          <div class="skel-line" style="width:30%;height:1.25rem;margin-bottom:0.5rem;"></div>
          <div class="skel-line" style="width:55%;height:0.75rem;margin-bottom:0.375rem;"></div>
          <div class="skel-line" style="width:40%;height:0.75rem;"></div>
        </div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(140px,1fr));gap:0.75rem;margin-bottom:1.5rem;">
        <div class="shimmer" style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"><div class="skel-line" style="width:60%;height:0.625rem;margin-bottom:0.5rem;"></div><div class="skel-line" style="width:40%;height:1.5rem;"></div></div>
        <div class="shimmer" style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"><div class="skel-line" style="width:60%;height:0.625rem;margin-bottom:0.5rem;"></div><div class="skel-line" style="width:40%;height:1.5rem;"></div></div>
        <div class="shimmer" style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"><div class="skel-line" style="width:60%;height:0.625rem;margin-bottom:0.5rem;"></div><div class="skel-line" style="width:40%;height:1.5rem;"></div></div>
        <div class="shimmer" style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"><div class="skel-line" style="width:60%;height:0.625rem;margin-bottom:0.5rem;"></div><div class="skel-line" style="width:40%;height:1.5rem;"></div></div>
      </div>
      <div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:1rem;">
        <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"></div>
        <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"></div>
        <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"></div>
        <div class="shimmer" style="aspect-ratio:1;border-radius:1rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.05);"></div>
      </div>
    </div>
  </section>

  <style>
    .skel-line{background:rgba(255,255,255,0.04);border-radius:0.25rem;}
    .shimmer{animation:shimmer-placeholder 1.5s ease-in-out infinite;}
    @keyframes shimmer-placeholder{0%{opacity:0.4;}50%{opacity:0.8;}100%{opacity:0.4;}}
    @keyframes count-pop{0%{transform:scale(1);}50%{transform:scale(1.12);}100%{transform:scale(1);}}
    .count-pop{animation:count-pop 0.4s cubic-bezier(0.34,1.56,0.64,1);}
  </style>

  <script is:inline>
    (function(){if(typeof window==='undefined')return;
      function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;');}
      function weiToFLR(w,d){d=d||4;try{const bi=BigInt(w||'0');const div=BigInt('1000000000000000000');const whole=(bi/div).toString();const frac=(bi%div).toString().padStart(18,'0').slice(0,d);return whole+'.'+frac;}catch(_){return'0.'+'0'.repeat(d);}}
      function shortAddr(a){if(!a||a.length<10)return a;return a.slice(0,6)+'...'+a.slice(-4);}
      function timeAgo(t){if(!t)return'';const d=Math.floor((Date.now()-new Date(t).getTime())/1000);if(d<60)return d+'s';if(d<3600)return Math.floor(d/60)+'m';if(d<86400)return Math.floor(d/3600)+'h';return Math.floor(d/86400)+'d';}
      function resolveImageUri(uri,tid){if(!uri)return'';if(uri.startsWith('/api/v1/img/')||uri.startsWith('data:'))return uri;return'/api/v1/media?url='+encodeURIComponent(uri)+'&id='+encodeURIComponent(tid||'');}
      function cur(){return (typeof window!=='undefined'&&window.MW_NATIVE_CURRENCY)||'C2FLR';}

      function isEthAddr(s){
        if(!s||s.length!==42||s.slice(0,2)!=='0x')return false;
        for(let i=2;i<42;i++){const c=s.charCodeAt(i);if(!((c>=48&&c<=57)||(c>=65&&c<=70)||(c>=97&&c<=102)))return false;}
        return true;
      }

      // Parse address from URL or localStorage
      const addr = (function(){
    const p = window.location.pathname.replace('/profile/','').replace('/profile','');
    if (isEthAddr(p)) return p.toLowerCase();
    try { const s = localStorage.getItem('mw_addr') || ''; return isEthAddr(s) ? s.toLowerCase() : ''; } catch(_) { return ''; }
  })();

      // JWT for authenticated requests
      function getJWT(){
        try { return localStorage.getItem('mw_jwt') || ''; } catch(_) { return ''; }
      }

      const root = document.getElementById('profile-root');
      if (!root) return;

      // Track last rendered address to skip no-op re-renders. Declared
      // BEFORE loadProfileData so the catch block (which resets it on
      // failure) and the mw-wallet-changed guard both reference it cleanly.
      var _lastRenderedAddr = addr;
      // Debounce timer for wallet-changed events (prevent rapid re-renders)
      var _wcDebounceTimer = null;
      // In-flight guard: prevent overlapping loadProfileData calls
      var _loading = false;

      // Compute isOwnProfile inside loadProfileData to stay fresh on wallet changes
      function isOwnProfileFor(targetAddr){
        const curConnected = (function(){
          try { const s = localStorage.getItem('mw_addr') || ''; return isEthAddr(s) ? s.toLowerCase() : ''; } catch(_) { return ''; }
        })();
        return curConnected && targetAddr && curConnected === targetAddr;
      }

      // Named function to load and render all profile data for a given address.
      // Called on initial page load AND on wallet change (without page reload).
      async function loadProfileData(targetAddr){
        // Prevent overlapping calls: if a load is already in-flight (e.g.
        // rapid wallet toggles beating the debounce), skip the duplicate.
        if (_loading) return;
        _loading = true;
        const encAddr = encodeURIComponent(targetAddr);
        root.innerHTML = '<div style="text-align:center;padding:2rem;opacity:0.4;"><div style="font-size:1.5rem;margin-bottom:0.5rem;">⌬</div><p style="font-size:0.8125rem;">Loading profile…</p></div>';
        try {
          const [pRes, nftRes, listRes, aucRes, offSentRes, offRecvRes, metRes, actRes] = await Promise.all([
        fetch('/api/v1/profile/'+encAddr).catch(function(){return null;}),
        fetch('/api/v1/wallet/'+encAddr+'/nfts').catch(function(){return null;}),
        fetch('/api/v1/listings?seller='+encAddr+'&limit=24').catch(function(){return null;}),
        fetch('/api/v1/auctions?seller='+encAddr+'&limit=20').catch(function(){return null;}),
        fetch('/api/v1/offers?bidder='+encAddr+'&limit=50').catch(function(){return null;}),
        fetch('/api/v1/offers?owner='+encAddr+'&limit=50').catch(function(){return null;}),
        fetch('/api/v1/metrics').catch(function(){return null;}),
        fetch('/api/v1/activity?address='+encAddr+'&limit=20').catch(function(){return null;})
      ]);

          function ok(r){return r&&r.ok;}
          async function safeJson(r){try{return await r.json();}catch(_){return null;}}

          const profile     = ok(pRes)    ? (await safeJson(pRes))    : null;
          let nfts        = ok(nftRes)  ? (await safeJson(nftRes))  : [];
          let listings    = ok(listRes) ? (await safeJson(listRes)) : [];
          let auctions    = ok(aucRes)  ? (await safeJson(aucRes))  : [];
          let offersSent  = ok(offSentRes) ? (await safeJson(offSentRes)) : [];
          let offersRecv  = ok(offRecvRes) ? (await safeJson(offRecvRes)) : [];
          const metrics     = ok(metRes)  ? ((await safeJson(metRes)) || {})  : {};
          let activity    = ok(actRes)  ? (await safeJson(actRes))  : [];

          if (!Array.isArray(nfts)) nfts = [];
          if (!Array.isArray(listings)) listings = [];
          if (!Array.isArray(auctions)) auctions = [];
          if (!Array.isArray(offersSent)) offersSent = [];
          if (!Array.isArray(offersRecv)) offersRecv = [];
          if (!Array.isArray(activity)) activity = [];

          const displayName = (profile && profile.display_name) || shortAddr(targetAddr);
          const bio         = (profile && profile.bio) || '';
          const avatar      = (profile && profile.avatar_uri) || '';
          const verified    = profile && profile.verified;

          // Compute user's total earnings from listings + auctions
          const totalListedWei = listings.reduce(function(s,l){try{return s+BigInt(l.price_wei||'0');}catch(_){return s;}},0n);
          const totalSentWei   = offersSent.reduce(function(s,o){try{return s+BigInt(o.amount_wei||'0');}catch(_){return s;}},0n);
          const totalRecvWei   = offersRecv.reduce(function(s,o){try{return s+BigInt(o.amount_wei||'0');}catch(_){return s;}},0n);

          // Platform metrics
          const mListings = metrics.totalActiveListings || metrics.listing_count || 0;
          const mSales    = metrics.totalSales || metrics.sales_count || 0;
          const mAuctions = metrics.totalAuctions || metrics.auction_count || 0;
          const mVolWei   = metrics.grossVolumeWei || metrics.volume_all || '0';

          function imgTag(src, fallback){
            if(!src) return '<span style="font-size:2.5rem;color:rgba(255,255,255,0.08);">'+fallback+'</span>';
            return '<img src="'+esc(src)+'" loading="lazy" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';"><span style="display:none;align-items:center;justify-content:center;position:absolute;inset:0;font-size:2.5rem;color:rgba(255,255,255,0.08);">'+fallback+'</span>';
          }

          function renderNFTGrid(items){
            if(!items||!items.length) return '<div style="padding:4rem;text-align:center;color:rgba(255,255,255,0.2);border-radius:1rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.05);">No items</div>';
            return '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(220px,1fr));gap:1rem;">'+items.map(function(it){
              const coll=it.collection||''; const tid=it.token_id||it.tokenID||'';
              const nm=it.name||('#'+esc(tid));
              const encC=encodeURIComponent(coll); const encT=encodeURIComponent(tid);
              const src=resolveImageUri(it.image_uri,it.token_id);
              const price=it.price_wei?weiToFLR(it.price_wei,4):'';
              return '<a href="/token/'+encC+'/'+encT+'" class="tilt-card" style="display:block;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.07);border-radius:1rem;overflow:hidden;transition:all 0.3s;">'+
                '<div style="aspect-ratio:1;overflow:hidden;background:rgba(9,9,11,0.5);position:relative;display:flex;align-items:center;justify-content:center;">'+
                  imgTag(src,'🖼')+
                  (price?'<div style="position:absolute;top:0.5rem;right:0.5rem;padding:0.25rem 0.625rem;border-radius:0.625rem;background:rgba(9,9,11,0.75);backdrop-filter:blur(8px);border:1px solid rgba(252,211,77,0.3);"><span style="font-size:0.75rem;font-weight:900;color:#fde68a;">'+esc(price)+'</span> <span style="font-size:0.5625rem;color:rgba(253,224,138,0.7);font-weight:700;">'+cur()+'</span></div>':'')+
                '</div>'+
                '<div style="padding:0.75rem;"><p style="font-size:0.5625rem;color:rgba(255,255,255,0.25);font-family:JetBrains Mono,monospace;">'+esc(shortAddr(coll))+'</p><p style="font-size:0.875rem;font-weight:700;color:#fafafa;">'+esc(nm)+'</p></div></a>';
            }).join('')+'</div>';
          }

          function renderListingsGrid(items){
            if(!items||!items.length) return '<div style="padding:4rem;text-align:center;color:rgba(255,255,255,0.2);">No active listings</div>';
            return renderNFTGrid(items); // Same visual for now
          }

          function renderAuctionsList(items){
            if(!items||!items.length) return '<div style="padding:4rem;text-align:center;color:rgba(255,255,255,0.2);">No auctions</div>';
            return '<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(240px,1fr));gap:1rem;">'+items.map(function(a){
              return '<a href="/auction/'+encodeURIComponent(String(a.auction_id))+'" style="display:block;background:rgba(15,15,19,0.6);border:1px solid rgba(167,139,250,0.2);border-radius:1rem;padding:1rem;transition:all 0.2s;">'+
                '<p style="font-size:0.8125rem;font-weight:700;color:#fafafa;">Auction #'+esc(String(a.auction_id))+'</p>'+
                '<p style="font-size:0.625rem;color:rgba(255,255,255,0.35);font-family:JetBrains Mono,monospace;margin-top:0.25rem;">'+esc(shortAddr(a.collection))+' #'+esc(a.token_id)+'</p>'+
                '<div style="display:flex;justify-content:space-between;align-items:center;margin-top:0.75rem;">'+
                  '<span style="font-size:0.625rem;padding:0.125rem 0.5rem;border-radius:1rem;background:rgba(167,139,250,0.12);color:#c4b5fd;font-weight:700;text-transform:uppercase;">'+esc(a.status||'active')+'</span>'+
                  '<span style="font-size:0.75rem;font-weight:700;color:#a78bfa;">'+weiToFLR(a.highest_bid_wei||a.reserve_price_wei||'0',2)+' '+cur()+' →</span>'+
                '</div></a>';
            }).join('')+'</div>';
          }

          function renderOffers(items, type){
            if(!items||!items.length) return '<div style="padding:3rem;text-align:center;color:rgba(255,255,255,0.2);">No '+type+' offers</div>';
            return '<div style="display:flex;flex-direction:column;gap:0.5rem;">'+items.map(function(o){
              const label = type==='sent' ? esc(shortAddr(o.collection))+' #'+esc(o.token_id) : 'From '+esc(shortAddr(o.bidder));
              const borderColor = type==='sent' ? 'rgba(252,211,77,0.12)' : 'rgba(125,211,252,0.12)';
              return '<a href="/token/'+encodeURIComponent(o.collection)+'/'+encodeURIComponent(o.token_id)+'" style="display:flex;align-items:center;justify-content:space-between;padding:1rem;border-radius:0.75rem;background:rgba(15,15,19,0.6);border:1px solid '+borderColor+';transition:all 0.2s;">'+
                '<div><p style="font-size:0.8125rem;font-weight:600;color:#fafafa;">'+label+'</p><p style="font-size:0.625rem;color:rgba(255,255,255,0.3);">'+esc(o.status||'pending')+'</p></div>'+
                '<span style="font-size:0.9375rem;font-weight:800;color:#fcd34d;">'+weiToFLR(o.amount_wei||o.principal_wei||'0')+' <span style="font-size:0.5625rem;opacity:0.6;">'+cur()+'</span></span></a>';
            }).join('')+'</div>';
          }

          function renderActivity(items){
            if(!items||!items.length) return '<div style="padding:3rem;text-align:center;color:rgba(255,255,255,0.2);">No recent activity</div>';
            const colorMap={Sold:'#fcd34d',Listed:'#7dd3fc',BidPlaced:'#a78bfa',AuctionCreated:'#a78bfa',OfferMade:'#fcd34d',OfferAccepted:'#7dd3fc'};
            return '<div style="display:flex;flex-direction:column;gap:0.5rem;">'+items.map(function(a){
              const c=colorMap[a.type]||'rgba(255,255,255,0.4)';
              return '<div style="display:flex;align-items:center;justify-content:space-between;padding:0.75rem 1rem;border-radius:0.75rem;background:rgba(15,15,19,0.5);border:1px solid rgba(255,255,255,0.04);">'+
                '<div style="display:flex;align-items:center;gap:0.75rem;">'+
                  '<span style="padding:0.125rem 0.5rem;border-radius:0.375rem;background:rgba(255,255,255,0.04);font-size:0.5625rem;font-weight:700;text-transform:uppercase;color:'+c+';">'+esc(a.type)+'</span>'+
                  '<span style="font-size:0.6875rem;color:rgba(255,255,255,0.35);font-family:JetBrains Mono,monospace;">'+esc(shortAddr(a.collection||''))+(a.tokenId?' #'+esc(a.tokenId):'')+'</span>'+
                '</div>'+
                '<div style="display:flex;align-items:center;gap:1rem;">'+
                  '<span style="font-size:0.75rem;font-weight:700;color:#fcd34d;">'+weiToFLR(a.amountWei||'0')+'</span>'+
                  '<span style="font-size:0.625rem;color:rgba(255,255,255,0.2);">'+timeAgo(a.timestamp)+'</span>'+
                '</div></div>';
            }).join('')+'</div>';
          }

          // If wallet returned empty but there are listings/auctions for this
          // address, show a note so the user understands why "My NFTs" is 0 —
          // the wallet may hold NFTs that aren't in tracked collections, or
          // the indexer hasn't processed recent transfers yet.
          var emptyWalletNotice = (!nfts || !nfts.length) && (listings.length + auctions.length > 0)
            ? '<div style="margin-bottom:1rem;padding:0.75rem 1rem;border-radius:0.75rem;background:rgba(125,211,252,0.08);border:1px solid rgba(125,211,252,0.15);"><p style="font-size:0.75rem;color:rgba(255,255,255,0.45);">💡 Your wallet has active listings/auctions but the indexer hasn&rsquo;t recorded any NFTs for this address yet. If you recently transferred NFTs to this wallet, they will appear after the next indexer sweep (≈2&hairsp;–&hairsp;5&thinsp;min).</p></div>'
            : '';

          // Build the complete profile page
          // Merge wallet-held NFTs with listed/auctioned NFTs so users see
          // their NFTs even when escrowed in the marketplace contract.
          var combinedNFTs = [];
          var seenKeys = {};
          // Helper: add to combinedNFTs, deduped by collection:token_id
          function mergeItems(arr){
            if(!arr||!arr.length)return;
            arr.forEach(function(it){
              var key = (it.collection||'')+':'+(it.token_id||it.tokenID||'');
              if(seenKeys[key])return;
              seenKeys[key]=true;
              combinedNFTs.push(it);
            });
          }
          // Priority: wallet-held > listed > auctioned (prefer held for latest info)
          mergeItems(nfts);
          mergeItems(listings);
          mergeItems(auctions);
          var allNFTsCount = combinedNFTs.length;

          const tabs = [
        {id:'nfts',     label:'My NFTs ('+allNFTsCount+')',     color:'#7dd3fc'},
        {id:'listings', label:'Listings ('+listings.length+')', color:'#fcd34d'},
        {id:'auctions', label:'Auctions ('+auctions.length+')', color:'#a78bfa'},
        {id:'offers',   label:'Offers ('+(offersSent.length+offersRecv.length)+')', color:'#fcd34d'},
        {id:'activity', label:'Activity ('+activity.length+')', color:'#7dd3fc'},
      ];

          root.innerHTML =
            // Header with avatar, name, bio
            '<div style="display:flex;flex-wrap:wrap;align-items:flex-start;gap:1.5rem;margin-bottom:1.5rem;padding:1.5rem;border-radius:1.25rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.07);backdrop-filter:blur(8px);">'+
              '<div style="width:4.5rem;height:4.5rem;border-radius:1rem;overflow:hidden;flex-shrink:0;position:relative;display:flex;align-items:center;justify-content:center;background:linear-gradient(135deg,rgba(125,211,252,0.2),rgba(124,58,237,0.15));border:1px solid rgba(255,255,255,0.08);">'+
                (avatar?'<img src="'+esc(avatar)+'" style="width:100%;height:100%;object-fit:cover;" onerror="this.style.display=\'none\';this.nextElementSibling.style.display=\'flex\';">':'')+
                '<span style="display:'+(avatar?'none':'flex')+';align-items:center;justify-content:center;width:100%;height:100%;font-size:2rem;">👤</span>'+
              '</div>'+
              '<div style="flex:1;min-width:0;">'+
                '<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">'+
                  '<h1 style="font-size:1.5rem;font-weight:800;color:#fafafa;">'+esc(displayName)+'</h1>'+
                  (verified?'<span style="padding:0.125rem 0.5rem;border-radius:2rem;background:rgba(167,139,250,0.15);border:1px solid rgba(167,139,250,0.3);color:#c4b5fd;font-size:0.625rem;font-weight:800;">✓ Verified</span>':'')+
                '</div>'+
                '<p style="font-size:0.75rem;color:rgba(255,255,255,0.3);font-family:JetBrains Mono,monospace;margin-top:0.25rem;">'+esc(targetAddr)+'</p>'+
                (bio?'<p style="font-size:0.875rem;color:rgba(255,255,255,0.55);margin-top:0.75rem;max-width:36rem;line-height:1.5;">'+esc(bio)+'</p>':'')+
                '<p style="font-size:0.75rem;color:#7dd3fc;margin-top:0.5rem;font-weight:700;">'+allNFTsCount+' NFT'+(allNFTsCount!==1?'s':'')+' — '+nfts.length+' in wallet, '+(listings.length+auctions.length)+' on market</p>'+
              '</div>'+
              '<div style="display:flex;align-items:center;gap:0.5rem;flex-shrink:0;">'+
                (isOwnProfileFor(targetAddr)?'<button id="edit-profile-btn" style="padding:0.5rem 1rem;border-radius:0.625rem;border:1px solid rgba(125,211,252,0.25);color:#7dd3fc;font-size:0.8125rem;font-weight:700;transition:all 0.2s;background:rgba(125,211,252,0.1);cursor:pointer;font-family:inherit;display:inline-flex;align-items:center;gap:0.375rem;">✎ Edit Profile</button>':'')+
                '<a href="/offers?addr='+encAddr+'" style="padding:0.5rem 1rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.1);color:rgba(255,255,255,0.6);font-size:0.8125rem;font-weight:600;transition:all 0.2s;flex-shrink:0;">View Offers →</a>'+
              '</div>'+
            '</div>'+

            // User metrics row
            '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(130px,1fr));gap:0.75rem;margin-bottom:1.5rem;">'+
              '<div style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.6);border:1px solid rgba(125,211,252,0.2);">'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;font-weight:700;margin-bottom:0.375rem;">Listings</p>'+
                '<p class="count-pop" style="font-size:1.5rem;font-weight:900;color:#7dd3fc;line-height:1;">'+listings.length+'</p>'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.2);margin-top:0.25rem;">'+weiToFLR(totalListedWei,2)+' '+cur()+' total</p>'+
              '</div>'+
              '<div style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.6);border:1px solid rgba(167,139,250,0.2);">'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;font-weight:700;margin-bottom:0.375rem;">Auctions</p>'+
                '<p class="count-pop" style="font-size:1.5rem;font-weight:900;color:#a78bfa;line-height:1;">'+auctions.length+'</p>'+
              '</div>'+
              '<div style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.6);border:1px solid rgba(252,211,77,0.2);">'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;font-weight:700;margin-bottom:0.375rem;">Offers Sent</p>'+
                '<p class="count-pop" style="font-size:1.5rem;font-weight:900;color:#fcd34d;line-height:1;">'+offersSent.length+'</p>'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.2);margin-top:0.25rem;">'+weiToFLR(totalSentWei,2)+' '+cur()+' escrowed</p>'+
              '</div>'+
              '<div style="padding:1rem;border-radius:0.875rem;background:rgba(15,15,19,0.6);border:1px solid rgba(255,255,255,0.1);">'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.35);text-transform:uppercase;font-weight:700;margin-bottom:0.375rem;">Offers Recv</p>'+
                '<p class="count-pop" style="font-size:1.5rem;font-weight:900;color:#fafafa;line-height:1;">'+offersRecv.length+'</p>'+
                '<p style="font-size:0.5625rem;color:rgba(255,255,255,0.2);margin-top:0.25rem;">'+weiToFLR(totalRecvWei,2)+' '+cur()+' offered</p>'+
              '</div>'+
            '</div>'+

            // Platform metrics section
            '<div style="padding:1.25rem;border-radius:0.875rem;background:rgba(15,15,19,0.4);border:1px solid rgba(255,255,255,0.06);margin-bottom:1.5rem;">'+
              '<h3 style="font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.3);text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.75rem;">Platform Metrics</h3>'+
              '<div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(120px,1fr));gap:0.75rem;">'+
                '<div><p style="font-size:0.5625rem;color:rgba(255,255,255,0.25);text-transform:uppercase;font-weight:700;">Total Listings</p><p style="font-size:1.25rem;font-weight:800;color:#fafafa;">'+mListings+'</p></div>'+
                '<div><p style="font-size:0.5625rem;color:rgba(255,255,255,0.25);text-transform:uppercase;font-weight:700;">Total Sales</p><p style="font-size:1.25rem;font-weight:800;color:#fcd34d;">'+mSales+'</p></div>'+
                '<div><p style="font-size:0.5625rem;color:rgba(255,255,255,0.25);text-transform:uppercase;font-weight:700;">Total Auctions</p><p style="font-size:1.25rem;font-weight:800;color:#a78bfa;">'+mAuctions+'</p></div>'+
                '<div><p style="font-size:0.5625rem;color:rgba(255,255,255,0.25);text-transform:uppercase;font-weight:700;">Gross Volume</p><p style="font-size:1.25rem;font-weight:800;color:#fafafa;">'+weiToFLR(mVolWei,2)+' <span style="font-size:0.5625rem;opacity:0.5;">'+cur()+'</span></p></div>'+
              '</div>'+
            '</div>'+

            // Empty wallet notice (if applicable — shown when user has
            // listings/auctions but zero NFTs recorded in nft_ownership)
            emptyWalletNotice +

            // Tab bar
            '<div id="tab-bar" style="display:flex;gap:0.25rem;margin-bottom:1.5rem;border-bottom:1px solid rgba(255,255,255,0.06);overflow-x:auto;">'+
              tabs.map(function(t){return '<button data-tab="'+t.id+'" class="profile-tab" style="padding:0.625rem 1rem;border:none;background:transparent;color:rgba(255,255,255,0.35);font-size:0.75rem;font-weight:700;text-transform:uppercase;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s;white-space:nowrap;font-family:inherit;">'+t.label+'</button>';}).join('')+
            '</div><div id="tab-content"></div>';

          // Tab switching
          function renderTab(id){
            const tc = document.getElementById('tab-content');
            if(!tc) return;
            switch(id){
              case 'nfts':     tc.innerHTML = renderNFTGrid(combinedNFTs); break;
              case 'listings': tc.innerHTML = renderListingsGrid(listings); break;
              case 'auctions': tc.innerHTML = renderAuctionsList(auctions); break;
              case 'offers':
                var html = '';
                if(offersSent.length) html += '<h4 style="font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.75rem;">Sent ('+offersSent.length+')</h4>'+renderOffers(offersSent,'sent');
                if(offersRecv.length) html += '<h4 style="font-size:0.75rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-top:1rem;margin-bottom:0.75rem;">Received ('+offersRecv.length+')</h4>'+renderOffers(offersRecv,'received');
                tc.innerHTML = html || '<div style="padding:4rem;text-align:center;color:rgba(255,255,255,0.2);">No offers yet</div>';
                break;
              case 'activity': tc.innerHTML = renderActivity(activity); break;
            }
          }

          const tabBar = document.getElementById('tab-bar');
          if(tabBar){
            tabBar.querySelectorAll('.profile-tab').forEach(function(btn){
              btn.addEventListener('click', function(){
                tabBar.querySelectorAll('.profile-tab').forEach(function(b){b.style.color='rgba(255,255,255,0.35)';b.style.borderBottomColor='transparent';});
                const t = tabs.find(function(t){return t.id===btn.dataset.tab;});
                btn.style.color = t?t.color:'#7dd3fc';
                btn.style.borderBottomColor = t?t.color:'#7dd3fc';
                renderTab(btn.dataset.tab);
              });
            });
            const first = tabBar.querySelector('.profile-tab');
            if(first) first.click();
          }

          // ── Edit Profile Modal ─────────────────────────────────────────────
          const editBtn = document.getElementById('edit-profile-btn');
          if(editBtn && isOwnProfileFor(targetAddr)){
            editBtn.addEventListener('click', function(){
              const overlay = document.createElement('div');
              overlay.id = 'edit-profile-overlay';
              overlay.style.cssText = 'position:fixed;inset:0;background:rgba(0,0,0,0.65);backdrop-filter:blur(6px);z-index:9999;display:flex;align-items:center;justify-content:center;padding:1rem;animation:fadeIn 0.2s ease;';

              const modal = document.createElement('div');
              modal.style.cssText = 'background:rgba(18,18,22,1);border:1px solid rgba(255,255,255,0.08);border-radius:1.25rem;padding:2rem;max-width:480px;width:100%;box-shadow:0 25px 60px rgba(0,0,0,0.5);animation:modalSlideUp 0.25s ease;';

              const currentDisplayName = profile && profile.display_name ? esc(profile.display_name) : '';
              const currentBio = profile && profile.bio ? esc(profile.bio) : '';
              const currentAvatar = profile && profile.avatar_uri ? esc(profile.avatar_uri) : '';
              const currentTwitter = profile && profile.twitter ? esc(profile.twitter) : '';
              const currentWebsite = profile && profile.website ? esc(profile.website) : '';

              modal.innerHTML =
                '<div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:1.5rem;">'+
                  '<h2 style="font-size:1.25rem;font-weight:800;color:#fafafa;">Edit Profile</h2>'+
                  '<button id="edit-profile-close" style="width:2rem;height:2rem;border-radius:0.5rem;border:none;background:rgba(255,255,255,0.04);color:rgba(255,255,255,0.3);cursor:pointer;font-size:1rem;display:flex;align-items:center;justify-content:center;font-family:inherit;transition:all 0.2s;">✕</button>'+
                '</div>'+
                '<form id="edit-profile-form" style="display:flex;flex-direction:column;gap:1rem;">'+
                  '<div><label style="display:block;font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.375rem;">Display Name</label>'+
                    '<input name="display_name" maxlength="64" value="'+currentDisplayName+'" placeholder="Your display name" style="width:100%;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:#fafafa;font-size:0.875rem;font-family:inherit;outline:none;transition:border-color 0.2s;box-sizing:border-box;">'+
                  '</div>'+
                  '<div><label style="display:block;font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.375rem;">Bio</label>'+
                    '<textarea name="bio" maxlength="500" placeholder="Tell the community about yourself…" style="width:100%;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:#fafafa;font-size:0.875rem;font-family:inherit;outline:none;resize:vertical;min-height:80px;transition:border-color 0.2s;box-sizing:border-box;">'+currentBio+'</textarea>'+
                  '</div>'+
                  '<div><label style="display:block;font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.375rem;">Avatar URL</label>'+
                    '<input name="avatar_uri" value="'+currentAvatar+'" placeholder="https://example.com/avatar.png" style="width:100%;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:#fafafa;font-size:0.875rem;font-family:inherit;outline:none;transition:border-color 0.2s;box-sizing:border-box;">'+
                  '</div>'+
                  '<div><label style="display:block;font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.375rem;">Twitter / X</label>'+
                    '<input name="twitter" value="'+currentTwitter+'" placeholder="@username or full URL" style="width:100%;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:#fafafa;font-size:0.875rem;font-family:inherit;outline:none;transition:border-color 0.2s;box-sizing:border-box;">'+
                  '</div>'+
                  '<div><label style="display:block;font-size:0.6875rem;font-weight:700;color:rgba(255,255,255,0.4);text-transform:uppercase;margin-bottom:0.375rem;">Website</label>'+
                    '<input name="website" value="'+currentWebsite+'" placeholder="https://yoursite.com" style="width:100%;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:rgba(255,255,255,0.04);color:#fafafa;font-size:0.875rem;font-family:inherit;outline:none;transition:border-color 0.2s;box-sizing:border-box;">'+
                  '</div>'+
                  '<div id="edit-profile-status" style="display:none;"></div>'+
                  '<div style="display:flex;gap:0.75rem;margin-top:0.5rem;">'+
                    '<button type="button" id="edit-profile-cancel" style="flex:1;padding:0.75rem;border-radius:0.625rem;border:1px solid rgba(255,255,255,0.08);background:transparent;color:rgba(255,255,255,0.5);font-weight:700;font-size:0.8125rem;cursor:pointer;font-family:inherit;transition:all 0.2s;">Cancel</button>'+
                    '<button type="submit" id="edit-profile-save" style="flex:1;padding:0.75rem;border-radius:0.625rem;border:none;background:linear-gradient(135deg,#7dd3fc,#0ea5e9);color:#09090b;font-weight:800;font-size:0.8125rem;cursor:pointer;font-family:inherit;transition:all 0.2s;box-shadow:0 0 20px -4px rgba(56,189,248,0.35);">Save Changes</button>'+
                  '</div>'+
                '</form>';

              overlay.appendChild(modal);
              document.body.appendChild(overlay);

              // Focus first input
              const firstInput = modal.querySelector('input[name="display_name"]');
              if(firstInput) setTimeout(function(){firstInput.focus();firstInput.select();}, 100);

              function closeModal(){
                if(overlay.parentNode) overlay.parentNode.removeChild(overlay);
              }

              // Close handlers
              const closeBtn = document.getElementById('edit-profile-close');
              if(closeBtn) closeBtn.addEventListener('click', closeModal);
              const cancelBtn = document.getElementById('edit-profile-cancel');
              if(cancelBtn) cancelBtn.addEventListener('click', closeModal);
              overlay.addEventListener('click', function(e){if(e.target===overlay) closeModal();});

              // ESC key
              function escHandler(e){if(e.key==='Escape'){closeModal();document.removeEventListener('keydown',escHandler);}}
              document.addEventListener('keydown', escHandler);

              // Focus/blur border color
              modal.querySelectorAll('input, textarea').forEach(function(el){
                el.addEventListener('focus', function(){this.style.borderColor = 'rgba(125,211,252,0.4)';});
                el.addEventListener('blur', function(){this.style.borderColor = 'rgba(255,255,255,0.08)';});
              });

              // Submit handler
              const form = document.getElementById('edit-profile-form');
              const statusEl = document.getElementById('edit-profile-status');
              const saveBtn = document.getElementById('edit-profile-save');

              form.addEventListener('submit', async function(e){
                e.preventDefault();
                const jwt = getJWT();
                if(!jwt){
                  statusEl.style.display = 'block';
                  statusEl.innerHTML = '<p style="color:#fca5a5;font-size:0.75rem;font-weight:600;">Please reconnect your wallet to edit</p>';
                  return;
                }

                const formData = new FormData(form);
                const payload = {
              display_name: (formData.get('display_name')||'').trim(),
              bio: (formData.get('bio')||'').trim(),
              avatar_uri: (formData.get('avatar_uri')||'').trim(),
              twitter: (formData.get('twitter')||'').trim(),
              website: (formData.get('website')||'').trim()
            };

                saveBtn.disabled = true;
                saveBtn.textContent = 'Saving…';
                saveBtn.style.opacity = '0.6';
                statusEl.style.display = 'none';

                try {
                  const res = await fetch('/api/v1/profile/'+encAddr, {
                method: 'PUT',
                headers: {
                  'Content-Type': 'application/json',
                  'Authorization': 'Bearer '+jwt
                },
                body: JSON.stringify(payload)
              });

                  if(res.ok){
                    statusEl.style.display = 'block';
                    statusEl.innerHTML = '<p style="color:#7dd3fc;font-size:0.75rem;font-weight:600;">✓ Profile saved!</p>';
                    // Re-render in-place instead of location.reload() — avoids
                    // a full page reload which would re-trigger the React
                    // hydration wallet-connect race we just fixed.
                    setTimeout(function(){
                      closeModal();
                      loadProfileData(targetAddr);
                    }, 800);
                  } else {
                    let errData;
                    try { errData = await res.json(); } catch(_){ errData = {error:'Unknown error'}; }
                    statusEl.style.display = 'block';
                    statusEl.innerHTML = '<p style="color:#fca5a5;font-size:0.75rem;font-weight:600;">✗ '+esc(errData.error||'Failed to save')+'</p>';
                    saveBtn.disabled = false;
                    saveBtn.textContent = 'Save Changes';
                    saveBtn.style.opacity = '1';
                  }
                } catch(err) {
                  statusEl.style.display = 'block';
                  statusEl.innerHTML = '<p style="color:#fca5a5;font-size:0.75rem;font-weight:600;">✗ Network error — please try again</p>';
                  saveBtn.disabled = false;
                  saveBtn.textContent = 'Save Changes';
                  saveBtn.style.opacity = '1';
                }
              });
            });
          }

        } catch(e) {
          // Reset last-rendered guard so the user isn't stuck — future wallet
          // events can retry loading even when the address hasn't changed
          // (e.g. after a transient API failure). _loading is reset in the
          // finally block below (don't duplicate it here).
          _lastRenderedAddr = null;
          if(root) root.innerHTML = '<div style="text-align:center;padding:4rem;color:rgba(255,255,255,0.3);"><p style="font-size:1rem;font-weight:700;color:#fca5a5;">Could not load profile</p><p style="font-size:0.8125rem;color:rgba(255,255,255,0.25);margin-top:0.5rem;">'+esc(e.message||'')+'</p><button onclick="window.__MW_APPKIT_OPEN__&&window.__MW_APPKIT_OPEN__()" style="margin-top:1rem;padding:0.75rem 2rem;border-radius:0.75rem;background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;font-weight:800;font-size:0.875rem;border:none;cursor:pointer;box-shadow:0 0 22px -6px rgba(167,139,250,0.45);font-family:inherit;">Connect Wallet</button></div>';
        } finally {
          _loading = false;
        }
      }

      // Listen for wallet-connect events — re-render profile IN-PLACE without page reload.
      // Debounce (500ms) to absorb rapid state transitions during wagmi React hydration
      // that fire multiple mw-wallet-changed events in quick succession. Also guard against
      // re-renders when the address hasn't actually changed (e.g. AppKit fires the event
      // during reconnect with the same address that was already stored).
      window.addEventListener('mw-wallet-changed', function _onWalletChange(){
        // Re-read the address from localStorage (may have changed or been cleared)
        const newAddr = (function(){
          const p = window.location.pathname.replace('/profile/','').replace('/profile','');
          if (isEthAddr(p)) return p.toLowerCase();
          try { const s = localStorage.getItem('mw_addr') || ''; return isEthAddr(s) ? s.toLowerCase() : ''; } catch(_) { return ''; }
        })();
        if (_wcDebounceTimer) clearTimeout(_wcDebounceTimer);
        _wcDebounceTimer = setTimeout(function(){
          _wcDebounceTimer = null;
          // Skip re-render if address hasn't changed — prevents unnecessary
          // re-fetches and visual flicker when wagmi reconnects with the
          // same wallet during page hydration.
          if (newAddr === _lastRenderedAddr) return;
          _lastRenderedAddr = newAddr;
          if (!newAddr) {
            // Wallet was disconnected — show connect screen
            if(root) root.innerHTML = '<div style="text-align:center;padding:4rem 1.5rem;"><div style="font-size:3rem;margin-bottom:1rem;opacity:0.3;">⌬</div><p style="font-size:1.25rem;font-weight:700;color:rgba(255,255,255,0.5);margin-bottom:0.5rem;">Connect your wallet</p><p style="font-size:0.875rem;color:rgba(255,255,255,0.25);">to view your profile, NFTs, and marketplace activity</p><button onclick="window.__MW_APPKIT_OPEN__&&window.__MW_APPKIT_OPEN__()" style="margin-top:1.5rem;padding:0.75rem 2rem;border-radius:0.75rem;background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;font-weight:800;font-size:0.875rem;border:none;cursor:pointer;box-shadow:0 0 22px -6px rgba(167,139,250,0.45);font-family:inherit;">Connect Wallet</button></div>';
            return;
          }
          // Re-fetch and re-render for the new/updated address
          loadProfileData(newAddr);
        }, 500);
      });

      // Initial load
      if (addr) {
        loadProfileData(addr);
      } else {
        root.innerHTML = '<div style="text-align:center;padding:4rem 1.5rem;"><div style="font-size:3rem;margin-bottom:1rem;opacity:0.3;">⌬</div><p style="font-size:1.25rem;font-weight:700;color:rgba(255,255,255,0.5);margin-bottom:0.5rem;">Connect your wallet</p><p style="font-size:0.875rem;color:rgba(255,255,255,0.25);">to view your profile, NFTs, and marketplace activity</p><button onclick="window.__MW_APPKIT_OPEN__&&window.__MW_APPKIT_OPEN__()" style="margin-top:1.5rem;padding:0.75rem 2rem;border-radius:0.75rem;background:linear-gradient(135deg,#a78bfa,#7c3aed);color:#fff;font-weight:800;font-size:0.875rem;border:none;cursor:pointer;box-shadow:0 0 22px -6px rgba(167,139,250,0.45);font-family:inherit;">Connect Wallet</button></div>';
      }
    })();
  </script>
</BaseLayout>
