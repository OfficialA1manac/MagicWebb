---
import BaseLayout from '../layouts/BaseLayout.astro';
import WalletConnect from '../components/WalletConnect';
import NFTGrid from '../components/NFTGrid.svelte';
---

<BaseLayout title="Listings" description="Browse active NFT listings on MagicWebb — buy and sell NFTs on Flare Network" activeNav="/listings">
  <WalletConnect slot="wallet" client:only="react" />

  <section style="max-width:80rem;margin:0 auto;padding:2rem 1.5rem;">
    <!-- Header -->
    <div class="reveal" style="display:flex;flex-wrap:wrap;align-items:center;justify-content:space-between;gap:1rem;margin-bottom:2rem;">
      <div>
        <h1 style="font-size:2rem;font-weight:800;color:#fafafa;display:flex;align-items:center;gap:0.75rem;letter-spacing:-0.02em;">
          <span style="width:2.75rem;height:2.75rem;border-radius:0.875rem;background:linear-gradient(135deg,#7dd3fc,#0ea5e9);display:flex;align-items:center;justify-content:center;color:#09090b;font-size:1.25rem;box-shadow:0 0 22px -6px rgba(56,189,248,0.45);">✦</span>
          Current Listings
        </h1>
        <p style="color:rgba(255,255,255,0.35);font-size:0.8125rem;margin-top:0.25rem;">Fixed-price sales across every tracked collection.</p>
      </div>
      <a href="/" style="font-size:0.8125rem;color:#7dd3fc;font-weight:700;transition:color 0.2s;">← Back home</a>
    </div>

    <!-- NFT Grid (Svelte component) -->
    <div class="reveal">
      <NFTGrid client:load />
    </div>
  </section>
</BaseLayout>
