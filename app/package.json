{
  "name": "magicwebb-app",
  "type": "module",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "astro dev --port 4321",
    "build": "astro build && npm run build:bridge",
    "build:bridge": "vite build --config vite.bridge.config.mjs",
    "preview": "astro preview --port 4321",
    "check": "astro check",
    "typecheck": "tsc --noEmit",
