    "lint:fix": "eslint src/ --fix",
    "test": "vitest run",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/react": "^4.0.0",
    "@astrojs/svelte": "^9.0.1",
    "@reown/appkit": "^1.8.22",
    "@reown/appkit-adapter-ethers": "^1.8.22",
    "@reown/appkit-adapter-wagmi": "^1.8.22",
    "@tanstack/react-query": "^5.101.2",
    "@wagmi/core": "^3.6.3",
    "astro": "^7.1.1",
    "ethers": "^6.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "svelte": "^5.56.6",
    "viem": "^2.55.4",
    "wagmi": "^2.14.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@eslint/js": "^10.0.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react": "^4.7.0",
    "eslint": "^10.7.0",
    "eslint-plugin-astro": "^2.1.1",
    "eslint-plugin-svelte": "^3.21.0",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "svelte-eslint-parser": "^1.8.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.64.0",
    "vitest": "^4.1.10"
