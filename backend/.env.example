# ── Required ──────────────────────────────────────────────────────────────────
# Supabase Postgres pooler URL (port 6543 = transaction mode, sslmode=require required)
POSTGRES_URL=postgres://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require&pool_mode=transaction

REDIS_URL=redis://localhost:6379

RPC_URL=https://coston2-api.flare.network/ext/C/rpc
CHAIN_ID=114

# Contract addresses (all lowercase)
MARKETPLACE_ADDR=0x0000000000000000000000000000000000000000
AUCTION_ADDR=0x0000000000000000000000000000000000000000
OFFERBOOK_ADDR=0x0000000000000000000000000000000000000000

# 32+ random hex bytes: openssl rand -hex 32
JWT_SECRET=

# Allowed CORS origin for the frontend
FRONTEND_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
ROYALTY_ADDR=
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=
PINATA_JWT=

# Auction keeper bot (hex-encoded ECDSA private key — enables auto-settlement)
KEEPER_KEY=

# Admin token for IndexerService.Reindex endpoint (empty = disabled)
SERVICE_TOKEN=

# Indexer tuning
INDEX_FROM_BLOCK=0
GETLOGS_CHUNK=30
GETLOGS_BLOCK_CAP=0

# Trending score weights
SCORE_W_VIEWS=0.3
SCORE_W_BIDS=0.5
SCORE_W_VOLUME=0.2
SCORE_DECAY=0.05
