# ───────────────────────────────────────────────────────────────────────────────
# MagicWebb backend configuration — copy to backend/.env and fill in.
# Required vars WITHOUT defaults will panic on startup; everything else is
# optional with sensible production defaults. All secrets live in .env ONLY
# (committed as .env.example for reference) — never check in real keys.
# ───────────────────────────────────────────────────────────────────────────────

# Runtime mode: "development" (verbose logs, no aggressive caching) vs
# "production" (structured, truncated logs, server caches on).
ENV=development

# Flare Coston2 testnet endpoint. The primary; supplementary endpoints (RPC_URLS,
# comma-separated) ADD redundant fallbacks but never silently REPLACE this one.
RPC_URL=https://coston2-api.flare.network/ext/C/rpc
CHAIN_ID=114

# Chain metadata — the WalletConnect v2 config block (chainId + name +
# currency + rpcUrl + explorerUrl). Single source of truth for the
# entire frontend: layout.html injects these as window.MW_NETWORK_NAME,
# window.MW_NETWORK_ID, window.MW_RPC_URL, window.MW_EXPLORER, and
# window.MW_NATIVE_CURRENCY, then wallet.js + every user-facing label
# (toast/ctaLabel/summary) reads from those globals. Defaults are
# Coston2-specific. The C2FLR currency symbol follows EIP-155 chain-list
# conventions — Coston2 uses the C2 prefix to disambiguate from other
# Flare networks. Set NETWORK_NAME, NATIVE_CURRENCY, EXPLORER_URL env vars
# to change the UI labels for a different network deployment.
NETWORK_NAME="Flare Coston2"
NATIVE_CURRENCY=C2FLR
EXPLORER_URL=https://coston2-explorer.flare.network

# Contract addresses — deployed via ./contracts to Flare Coston2 (or local).
# LOWER-CASE on input; cmd/server normalizes. The UI template injects them
# into every page so a redeploy never strands wallet actions on dead addresses.
MARKETPLACE_ADDR=0x…
AUCTION_ADDR=0x…
OFFERBOOK_ADDR=0x…
# Royalty receiver (optional). When unset, all sales route to the contract
# deployer. Leave blank for the seller-pays model used by default.
ROYALTY_ADDR=

# Postgres connection. Pool sizing comes from URL params (default 10/20).
POSTGRES_URL=postgres://user:pass@localhost:5432/magicwebb?sslmode=disable

# (Optional) Redis connection for distributed cache (CACHE-1). When set, the
# trending and activity caches share state across ALL running instances via
# Redis, eliminating per-instance cache inconsistency. When empty (default),
# the caches are per-process in-memory only — simpler but each deploy resets
# them. Uses github.com/redis/go-redis/v9 with build tag `redis`:
#   go build -tags redis ./cmd/server
# Without the build tag, REDIS_URL is ignored and in-memory caches are used.
# REDIS_URL=redis://localhost:6379/0

# HTTP listen addr. Default ":8080" — explicitly set in production behind a
# reverse proxy so the bound port matches your routing config (e.g. ":3000").
HTTP_ADDR=:8080

# JWT secret used for SIWE-derived session tokens. MUST be ≥32 chars; the
# config loader panics on shorter values. Rotate via env swap + restart.
JWT_SECRET=replace-this-with-32-plus-chars-of-random-data-please-please

# Allowed CORS origin. For local dev: "http://localhost:3000".
FRONTEND_URL=http://localhost:3000

# WalletConnect v2 project ID (cloud.walletconnect.com). Enables the QR
# pairing flow in the wallet picker. Empty = MetaMask/injected-only mode.
# Get a projectId at https://cloud.walletconnect.com — it is free and any
# project can use any ID; the constraint is "yours = yours forever" so
# don't share it after a future migration.
WC_PROJECT_ID=your_walletconnect_project_id_here

# SIWE nonce TTL — Go duration string (e.g. "5m", "30s", "1h"). Controls
# how long an issued SIWE nonce remains valid before the next /auth/nonce call
# is required. Default 5m.
NONCE_TTL=5m

# Max concurrent metadata fetches per indexer tick. Each fetch calls tokenURI
# on-chain + GETs the JSON body from an IPFS/HTTP gateway. Bounding prevents
# a burst of missing metadata from hammering RPCs and gateways. Default 3.
METADATA_CONCURRENCY=3

# NFT contract addresses the indexer must watch for Transfer events.
# Comma-separated, case-insensitive. The indexer auto-seeds tracked_collections
# when a listing or auction is created from a collection; this env var lets you
# add collections that have never been listed or auctioned on the marketplace —
# without it, WalletNFTs returns empty for NFTs from those collections.
# Example: the deployed MagicWebbNFT contract.
TRACKED_COLLECTIONS=0xe96Afb7b664Ab90d74b778AdFE47D8342495807F

# (Optional) Sepolia indexer override. Default = 0 = live catch-up from
# the genesis block; bump this for faster catch-up but you lose history.
INDEX_FROM_BLOCK=0

# Admin allowlist — comma-separated lower-cased addresses. Off-chain admin
# actions (profile verification, settlement optional bypass) require the
# JWT's address to be in this list. Empty = no admin endpoints available.
ADMIN_ALLOWLIST=

# (No Pinata / IPFS dependency — all assets self-hosted in Postgres BYTEA)

# Keeper bot ECDSA private key. Hex, no 0x prefix. When set, the indexer
# runs a worker that auto-settles auctions older than 5min past endAt. Be
# careful: this account pays gas on every settlement.
KEEPER_KEY=

# Gas cost alerting webhook — Discord or Slack-compatible webhook URL.
# When set along with GAS_ALERT_THRESHOLD_WEI, the keeper sends an alert
# whenever aggregate gas costs in a 24-hour window exceed the threshold.
# The webhook receives a JSON POST with a red-coloured embed card.
# Prometheus Alertmanager-compatible webhook URL is set via:
# PROMETHEUS_WEBHOOK_URL=https://alertmanager.example.com/api/v1/alerts
DISCORD_WEBHOOK_URL=

# Gas cost alert threshold in wei. Default 0.5 native tokens (500000000000000000).
# When total keeper gas cost in the last 24 hours exceeds this, a webhook alert
# is sent. Cooldown of 1 hour prevents spam.
GAS_ALERT_THRESHOLD_WEI=500000000000000000

# SMTP email alerting — optional alternative channel for gas cost alerts.
# When SMTP_HOST and EMAIL_TO are configured, email alerts are sent alongside
# any configured webhook URLs. The email body is an HTML template with cost
# breakdown and a link to the gas metrics dashboard.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# EMAIL_FROM=Keeper Alerts <your-email@gmail.com>
# EMAIL_TO=ops@example.com

# v29 audit F-03: hard ceilings on the keeper's gas pricing. Public RPCs can
# spike their fee/tip suggestions during network congestion; without caps, a
# single keeper tx could drain the keeper wallet. Units are gwei. Set to 0 to
# disable (NOT recommended on testnet OR mainnet). Defaults are 100/5 gwei,
# which leaves ample headroom on Coston2.
KEEPER_MAX_FEE_CAP_GWEI=100
KEEPER_MAX_TIP_CAP_GWEI=5

# Admin token for IndexerService.Reindex RPC. Empty disables the endpoint.
SERVICE_TOKEN=
